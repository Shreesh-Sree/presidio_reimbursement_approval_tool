# Local backend credentials and machine-specific development configuration.
backend/.env
backend/.env.local

# Vite values are machine-specific too. Clerk publishable keys are public, but
# local API endpoints and any accidental credentials must never be staged.
frontend/.env*
!frontend/.env.example

# Python bytecode generated by local development and test runs.
__pycache__/
*.py[cod]

# Local tool installers and archives are never project source.
aws/
awscliv2.zip

# Local links created by the hosting CLIs. Project IDs and deployment metadata
# are environment-specific and must not become source-controlled configuration.
.vercel/
.railway/

# Local agent/tool state and environment-specific deployment links.
.claude/
CLAUDE.md
.agents/
.kilo/
.neon
.local-storage/
deployment/terraform/backend.hcl
deployment/terraform-azure/.terraform/
deployment/terraform-azure/terraform.tfstate
deployment/terraform-azure/terraform.tfstate.backup
deployment/terraform-azure/terraform.tfvars
deployment/terraform-azure/.terraform.lock.hcl
receipt_intelligence_service/.env
.vercel
secrets.txt

# Generated Playwright artifacts.
frontend/test-results/
frontend/playwright-report/

# Local one-off diagnostics and generated database files.
scratch_*.py
*.db
