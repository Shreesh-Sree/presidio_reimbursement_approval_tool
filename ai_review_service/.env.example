# Copy to a local .env only for development. Never commit a real provider key.
AI_REVIEW_DATABASE_PATH=var/ai-review.sqlite3
AI_REVIEW_PROVIDER=rule_based

# Configure exactly one optional provider. Store vendor keys in a secret manager
# or an ignored local .env; leave unused provider keys empty.
AI_REVIEW_GEMINI_API_KEY=
AI_REVIEW_GEMINI_MODEL=gemini-2.5-flash
AI_REVIEW_GROQ_API_KEY=
AI_REVIEW_GROQ_MODEL=openai/gpt-oss-20b

AI_REVIEW_PROVIDER_TIMEOUT_SECONDS=8
AI_REVIEW_PROVIDER_MAX_ATTEMPTS=2
AI_REVIEW_PROVIDER_RETRY_BACKOFF_SECONDS=0.25
AI_REVIEW_SERVICE_TOKEN=
