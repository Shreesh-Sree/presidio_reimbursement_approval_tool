DATABASE_URL=postgresql://reimbursement:password@localhost:5432/reimbursement_dev
JWT_SECRET=your-secret-key-here-change-in-production
# Explicitly set local/test/staging/production. Production defaults are strict
# and reject wildcard CORS and local attachment storage.
DEPLOYMENT_ENVIRONMENT=local
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# OAuth-only browser access via Supabase Auth.
AUTH_PROVIDER=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=
# The one verified work email that can provision the first app administrator.
# Keep its real value in an ignored .env or secret manager, never source code.
SUPER_ADMIN_EMAIL=admin@example.com
DEFAULT_ORGANIZATION_NAME=Presidio
DEFAULT_ORGANIZATION_CODE=PRESIDIO
DEFAULT_DEPARTMENT_NAME=General
DEFAULT_DEPARTMENT_CODE=GENERAL
# Local password mode is deliberately migration/test-only. Do not expose its
# routes in normal development or deployed environments.
# AUTH_PROVIDER=local
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@presidio.com
# Delivery is opt-in; disabled environments retain queued email records safely.
EMAIL_DELIVERY_ENABLED=false
SMTP_USE_TLS=false
SMTP_TIMEOUT_SECONDS=10
# Azure Communication Services for production email delivery.
# When set, email is sent via Azure instead of SMTP. SMTP remains for local dev.
AZURE_COMMUNICATION_CONNECTION_STRING=
AZURE_COMMUNICATION_SENDER=DoNotReply@your-domain.azurecomm.net
AWS_REGION=us-east-1
S3_BUCKET=reimbursement-dev
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
# Local is only for explicit local/test use. Azure production uses managed
# identity; do not set an account connection string in deployed environments.
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=.local-storage
AZURE_STORAGE_ACCOUNT_URL=
AZURE_STORAGE_CONTAINER=uploads
AZURE_STORAGE_CONNECTION_STRING=
MAX_POLICY_DOCUMENT_BYTES=15728640
MAX_RECEIPT_BYTES=10485760

# Optional, internal-only advisory AI service. The AI service owns its own DB.
AI_REVIEW_SERVICE_URL=
AI_REVIEW_SERVICE_TOKEN=
# Stable, dedicated HMAC key for non-reversible AI service references.
AI_REVIEW_REFERENCE_HMAC_KEY=
AI_REVIEW_TIMEOUT_SECONDS=2

# Optional, internal-only receipt-intelligence service.
RECEIPT_INTELLIGENCE_SERVICE_URL=
RECEIPT_INTELLIGENCE_SERVICE_TOKEN=
RECEIPT_INTELLIGENCE_TIMEOUT_SECONDS=4
# Default-deny organization allowlist for minimized text leaving the receipt
# service. It is effective only when that service also enables its own egress
# switch; store real UUIDs in the deployment secret/configuration system.
RECEIPT_INTELLIGENCE_EXTERNAL_PROVIDER_ORGANIZATION_IDS=

# Optional, internal-only policy assistant. This is a core-client configuration;
# the assistant service itself still owns its separate SQLite configuration.
POLICY_ASSISTANT_SERVICE_URL=
POLICY_ASSISTANT_SERVICE_TOKEN=
# Stable, dedicated HMAC key for non-reversible policy scope references.
POLICY_ASSISTANT_REFERENCE_HMAC_KEY=
POLICY_ASSISTANT_TIMEOUT_SECONDS=4
