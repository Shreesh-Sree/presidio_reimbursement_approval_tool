Project presidio_reimbursement_approval_tool {
  database_type: 'PostgreSQL'
  Note: 'Authoritative core-application schema. AI review, receipt intelligence, and policy assistant own separate SQLite datastores and are intentionally not represented here.'
}

Enum organization_status { active inactive }
Enum user_status { active inactive suspended }
Enum report_status { draft submitted approved_pending_payment paid rejected sent_back }
Enum approval_status { pending approved rejected sent_back escalated }
Enum payment_status { pending batched exported paid failed }
Enum payment_batch_status { created exported }
Enum notification_channel { in_app email push sms }
Enum notification_status { pending sent failed }

Table organizations {
  id uuid [pk]
  name varchar(255) [not null]
  code varchar(50) [not null, unique]
  base_currency varchar(10) [not null, default: 'INR']
  status organization_status [not null, default: 'active']
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
}

Table departments {
  id uuid [pk]
  organization_id uuid [not null, ref: > organizations.id]
  department_head_user_id uuid [note: 'Validated by service; intentionally no FK to avoid creation cycle']
  code varchar(50) [not null]
  name varchar(255) [not null]
  status organization_status [not null, default: 'active']
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
  indexes { (organization_id, code) [unique] }
}

Table users {
  id uuid [pk]
  organization_id uuid [not null, ref: > organizations.id]
  department_id uuid [not null, ref: > departments.id]
  manager_user_id uuid [ref: > users.id]
  employee_number varchar(50) [not null]
  username varchar(100) [not null]
  email varchar(255) [not null]
  password_hash text [note: 'Nullable for OAuth-created users']
  external_auth_subject varchar(255) [unique]
  full_name varchar(255) [not null]
  designation varchar(255)
  phone varchar(50)
  status user_status [not null, default: 'active']
  last_login_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
  indexes {
    (organization_id, employee_number) [unique]
    (organization_id, username) [unique]
    (organization_id, email) [unique]
    (organization_id, status)
  }
}

Table roles {
  id uuid [pk]
  code varchar(100) [not null, unique]
  name varchar(150) [not null]
  description text
  is_system_role boolean [not null, default: false]
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
}

Table permissions {
  id uuid [pk]
  code varchar(150) [not null, unique]
  module varchar(100) [not null]
  action varchar(100) [not null]
  description text
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
  indexes { (module, action) [unique] }
}

Table user_roles {
  id uuid [pk]
  user_id uuid [not null, ref: > users.id]
  role_id uuid [not null, ref: > roles.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
  indexes { (user_id, role_id) [unique] }
}

Table role_permissions {
  id uuid [pk]
  role_id uuid [not null, ref: > roles.id]
  permission_id uuid [not null, ref: > permissions.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
  indexes { (role_id, permission_id) [unique] }
}

Table expense_categories {
  id uuid [pk]
  parent_category_id uuid [ref: > expense_categories.id]
  code varchar(100) [not null, unique]
  name varchar(150) [not null]
  description varchar(500)
  receipt_required boolean [not null, default: true]
  max_amount numeric(18,2)
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
}

Table vendors {
  id uuid [pk]
  name varchar(255) [not null]
  normalized_name varchar(255) [not null, unique]
  description varchar(500)
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
}

Table policies {
  id uuid [pk]
  organization_id uuid [not null, ref: > organizations.id]
  name varchar(255) [not null]
  version_label varchar(50) [not null]
  is_active boolean [not null, default: false]
  effective_from timestamptz [not null]
  effective_to timestamptz
  uploaded_document_attachment_id uuid [note: 'Attachment is polymorphic; no physical FK']
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
  indexes { (organization_id, name, version_label) [unique] }
}

Table policy_rules {
  id uuid [pk]
  policy_id uuid [not null, ref: > policies.id]
  category_id uuid [ref: > expense_categories.id]
  vendor_id uuid [ref: > vendors.id]
  max_per_day numeric(18,2)
  max_per_trip numeric(18,2)
  per_category_cap numeric(18,2)
  receipt_required_above numeric(18,2)
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
  indexes { (policy_id, category_id, vendor_id) [unique] }
}

Table workflow_rules {
  id uuid [pk]
  name varchar(255) [not null, unique]
  conditions_json jsonb [not null, default: `'{}'`]
  approval_chain_json jsonb [not null, default: `'[]'`]
  priority integer [not null, default: 100]
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
}

Table expense_reports {
  id uuid [pk]
  report_number varchar(50) [not null, unique]
  employee_user_id uuid [not null, ref: > users.id]
  department_id uuid [not null, ref: > departments.id]
  workflow_rule_id uuid [ref: > workflow_rules.id]
  applied_policy_id uuid [ref: > policies.id]
  title varchar(255) [not null]
  description text
  start_date date
  end_date date
  currency_code varchar(10) [not null, default: 'USD']
  status report_status [not null, default: 'draft']
  total_amount numeric(18,2) [not null, default: 0]
  last_saved_at timestamptz
  submitted_at timestamptz
  ai_review_job_id uuid [note: 'Opaque pointer to isolated AI review datastore']
  ai_review_requested_at timestamptz
  remarks text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
  indexes { (employee_user_id, status) (department_id, status) }
}

Table expense_items {
  id uuid [pk]
  expense_report_id uuid [not null, ref: > expense_reports.id]
  line_number integer [not null]
  category_id uuid [not null, ref: > expense_categories.id]
  vendor_id uuid [ref: > vendors.id]
  merchant_name varchar(255)
  amount numeric(18,2) [not null]
  original_amount numeric(18,2)
  currency_code varchar(10)
  exchange_rate numeric(10,6)
  expense_date date [not null]
  description text
  is_policy_violated boolean [not null, default: false]
  policy_violation_reason text
  remarks text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
  indexes { (expense_report_id, line_number) [unique] }
}

Table attachments {
  id uuid [pk]
  entity_type varchar(100) [not null, note: 'Polymorphic owner type']
  entity_id uuid [not null, note: 'Polymorphic owner ID']
  file_name varchar(255) [not null]
  original_file_name varchar(255) [not null]
  storage_path text [not null]
  mime_type varchar(150) [not null]
  file_size_bytes bigint [not null]
  checksum varchar(128) [not null]
  uploaded_by uuid [not null, ref: > users.id]
  uploaded_at timestamptz [not null, default: `now()`]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
  indexes { (entity_type, entity_id) (checksum) }
}

Table delegations {
  id uuid [pk]
  delegator_user_id uuid [not null, ref: > users.id]
  delegate_user_id uuid [not null, ref: > users.id]
  start_date timestamptz [not null]
  end_date timestamptz [not null]
  scope varchar(20) [not null, default: 'all']
  is_active boolean [not null, default: true]
  remarks text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
}

Table approval_levels {
  id uuid [pk]
  expense_report_id uuid [not null, ref: > expense_reports.id]
  approver_user_id uuid [not null, ref: > users.id]
  original_approver_user_id uuid [ref: > users.id]
  delegation_id uuid [ref: > delegations.id]
  level_number integer [not null]
  status approval_status [not null, default: 'pending']
  decision_date timestamptz
  due_at timestamptz
  reminder_sent_at timestamptz
  escalated_at timestamptz
  is_parallel boolean [not null, default: false]
  remarks text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
  indexes { (expense_report_id, level_number, approver_user_id) [unique] }
}

Table approval_history {
  id uuid [pk]
  expense_report_id uuid [not null, ref: > expense_reports.id]
  approval_level_id uuid [ref: > approval_levels.id]
  action varchar(20) [not null]
  performed_by uuid [ref: > users.id]
  acting_for_user_id uuid [ref: > users.id]
  performed_at timestamptz [not null, default: `now()`]
  remarks text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
}

Table comments {
  id uuid [pk]
  expense_report_id uuid [not null, ref: > expense_reports.id]
  parent_comment_id uuid [ref: > comments.id]
  user_id uuid [not null, ref: > users.id]
  visibility varchar(20) [not null, default: 'public']
  comment_text text [not null]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
}

Table notifications {
  id uuid [pk]
  recipient_user_id uuid [not null, ref: > users.id]
  template_code varchar(100) [not null]
  channel notification_channel [not null, default: 'in_app']
  status notification_status [not null, default: 'pending']
  payload jsonb [not null, default: `'{}'`]
  sent_at timestamptz
  read_at timestamptz
  delivery_error text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
}

Table payment_batches {
  id uuid [pk]
  organization_id uuid [not null, ref: > organizations.id]
  batch_reference varchar(150) [not null]
  status payment_batch_status [not null, default: 'created']
  currency_code varchar(10) [not null]
  total_amount numeric(18,2) [not null]
  payment_count integer [not null]
  created_by uuid [not null, ref: > users.id]
  exported_at timestamptz
  remarks text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
  indexes { (organization_id, batch_reference) [unique] (organization_id, status) }
}

Table payment_records {
  id uuid [pk]
  expense_report_id uuid [not null, ref: > expense_reports.id]
  payment_batch_id uuid [ref: > payment_batches.id]
  bank_detail_id uuid [note: 'Reserved for a future bounded context; intentionally no FK']
  payment_reference varchar(150) [not null, unique]
  payment_date date
  exported_at timestamptz
  amount numeric(18,2) [not null]
  status payment_status [not null, default: 'pending']
  provider_reference varchar(150)
  failure_reason text
  processed_by uuid [ref: > users.id]
  remarks text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
  indexes { expense_report_id [unique] (payment_batch_id, status) }
}

Table payment_events {
  id uuid [pk]
  payment_record_id uuid [not null, ref: > payment_records.id]
  payment_batch_id uuid [ref: > payment_batches.id]
  event_type varchar(40) [not null]
  from_status payment_status
  to_status payment_status [not null]
  amount numeric(18,2) [not null]
  provider_reference varchar(150)
  remarks text
  performed_by uuid [ref: > users.id]
  occurred_at timestamptz [not null, default: `now()`]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
}

Table sessions {
  id uuid [pk]
  user_id uuid [not null, ref: > users.id]
  session_token_hash text [not null, unique]
  ip_address varchar(100)
  user_agent text
  expires_at timestamptz [not null]
  revoked_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
}

Table audit_logs {
  id uuid [pk]
  entity_name varchar(100) [not null]
  record_id varchar(36) [not null]
  operation varchar(50) [not null]
  before_json text
  after_json text
  performed_by varchar(36)
  request_meta text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]
  indexes { (entity_name, record_id) }
}
