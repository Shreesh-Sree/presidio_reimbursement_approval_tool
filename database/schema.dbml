Project enterprise_expense_reimbursement_approval_system_presidio_intern {
  database_type: 'PostgreSQL'
  Note: 'Simplified single-company DBML schema for an enterprise expense reimbursement approval system.'
}

Enum common_status {
  active
  inactive
}

Enum user_status {
  active
  inactive
  suspended
}

Enum report_status {
  draft
  submitted
  approved
  rejected
  paid
}

Enum approval_status {
  pending
  approved
  rejected
}

Enum approval_action {
  approve
  reject
  forward
}

Enum payment_status {
  pending
  processed
  failed
}

Enum notification_status {
  pending
  sent
  failed
}

Enum notification_channel {
  email
  push
  sms
}

Enum comment_visibility {
  public
  approvers_only
  private
}

Enum audit_operation {
  insert
  update
  delete
}

Enum delegation_scope {
  all
  expenses
  approvals
}

Table organizations {
  id uuid [pk, default: `gen_random_uuid()`]
  name varchar(255) [not null]
  code varchar(50) [not null, unique]
  base_currency varchar(10) [not null, default: 'INR']
  status common_status [not null, default: 'active']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]

  indexes {
    (code) [unique]
    (status)
    (is_deleted)
  }
}

Table departments {
  id uuid [pk, default: `gen_random_uuid()`]
  organization_id uuid [not null, ref: > organizations.id]
  department_head_user_id uuid [ref: > users.id]
  code varchar(50) [not null]
  name varchar(255) [not null]
  status common_status [not null, default: 'active']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]

  indexes {
    (organization_id, code) [unique]
    (department_head_user_id)
    (status)
    (is_deleted)
  }
}

Table users {
  id uuid [pk, default: `gen_random_uuid()`]
  organization_id uuid [not null, ref: > organizations.id]
  department_id uuid [not null, ref: > departments.id]
  manager_user_id uuid [ref: > users.id, note: 'Self-reference because managers are employees']
  employee_number varchar(50) [not null]
  username varchar(100) [not null]
  email varchar(255) [not null]
  password_hash text [not null]
  full_name varchar(255) [not null]
  designation varchar(255)
  phone varchar(50)
  status user_status [not null, default: 'active']
  last_login_at timestamp
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]

  indexes {
    (organization_id, employee_number) [unique]
    (organization_id, username) [unique]
    (organization_id, email) [unique]
    (department_id)
    (manager_user_id)
    (status)
    (is_deleted)
  }
}

Table roles {
  id uuid [pk, default: `gen_random_uuid()`]
  code varchar(100) [not null, unique]
  name varchar(150) [not null]
  description text
  is_system_role boolean [not null, default: false]
  is_active boolean [not null, default: true]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]

  indexes {
    (code) [unique]
    (is_active)
    (is_deleted)
  }
}

Table permissions {
  id uuid [pk, default: `gen_random_uuid()`]
  code varchar(150) [not null, unique]
  module varchar(100) [not null]
  action varchar(100) [not null]
  description text
  is_active boolean [not null, default: true]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]

  indexes {
    (code) [unique]
    (module, action) [unique]
    (is_active)
    (is_deleted)
  }
}

Table user_roles {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null, ref: > users.id]
  role_id uuid [not null, ref: > roles.id]
  is_active boolean [not null, default: true]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]

  indexes {
    (user_id, role_id) [unique]
    (role_id)
    (is_active)
    (is_deleted)
  }
}

Table role_permissions {
  id uuid [pk, default: `gen_random_uuid()`]
  role_id uuid [not null, ref: > roles.id]
  permission_id uuid [not null, ref: > permissions.id]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]

  indexes {
    (role_id, permission_id) [unique]
    (permission_id)
    (is_deleted)
  }
}

}

Table expense_categories {
  id uuid [pk, default: `gen_random_uuid()`]
  parent_category_id uuid [ref: > expense_categories.id, note: 'Self-reference for category hierarchy']
  code varchar(100) [not null, unique]
  name varchar(150) [not null]
  description text
  receipt_required boolean [not null, default: true]
  max_amount decimal(18,2)
  status common_status [not null, default: 'active']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]

  indexes {
    (code) [unique]
    (parent_category_id)
    (status)
    (is_deleted)
  }
}

Table vendors {
  id uuid [pk, default: `gen_random_uuid()`]
  name varchar(255) [not null]
  normalized_name varchar(255) [not null, unique]
  description text
  status common_status [not null, default: 'active']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]

  indexes {
    (normalized_name) [unique]
    (status)
    (is_deleted)
  }
}

Table expense_reports {
  id uuid [pk, default: `gen_random_uuid()`]
  report_number varchar(50) [not null, unique]
  employee_user_id uuid [not null, ref: > users.id]
  department_id uuid [not null, ref: > departments.id]
  workflow_rule_id uuid [ref: > workflow_rules.id]
  title varchar(255) [not null]
  description text
  status report_status [not null, default: 'draft']
  total_amount decimal(18,2) [not null, default: 0]
  last_saved_at timestamp [not null, default: `now()`]
  submitted_at timestamp
  remarks text
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]

  indexes {
    (report_number) [unique]
    (employee_user_id, created_at)
    (department_id, status)
    (workflow_rule_id)
    (is_deleted)
  }
}

Table expense_items {
  id uuid [pk, default: `gen_random_uuid()`]
  expense_report_id uuid [not null, ref: > expense_reports.id]
  line_number integer [not null]
  category_id uuid [not null, ref: > expense_categories.id]
  vendor_id uuid [ref: > vendors.id]
  merchant_name varchar(255)
  amount decimal(18,2) [not null, note: 'Amount in base currency']
  original_amount decimal(18,2)
  currency_code varchar(10)
  exchange_rate decimal(10,6)
  expense_date date [not null]
  description text
  is_policy_violated boolean [not null, default: false]
  policy_violation_reason text
  status approval_status [not null, default: 'pending']
  remarks text
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]

  indexes {
    (expense_report_id, line_number) [unique]
    (category_id)
    (project_id)
    (vendor_id)
    (expense_date)
    (status)
    (is_policy_violated)
    (is_deleted)
  }
}

Table attachments {
  id uuid [pk, default: `gen_random_uuid()`]
  entity_type varchar(100) [not null, note: 'expense_report, expense_item, comment, or future owner type']
  entity_id uuid [not null]
  file_name varchar(255) [not null]
  original_file_name varchar(255) [not null]
  storage_path text [not null]
  mime_type varchar(150) [not null]
  file_size_bytes bigint [not null]
  checksum varchar(128) [not null]
  uploaded_by uuid [not null, ref: > users.id]
  uploaded_at timestamp [not null, default: `now()`]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]

  indexes {
    (entity_type, entity_id)
    (checksum)
    (uploaded_by)
    (is_deleted)
  }
}

Table workflow_rules {
  id uuid [pk, default: `gen_random_uuid()`]
  name varchar(255) [not null, unique]
  conditions_json jsonb [not null, default: `'{}'`]
  approval_chain_json jsonb [not null, default: `'[]'`]
  priority integer [not null, default: 100]
  is_active boolean [not null, default: true]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]

  indexes {
    (name) [unique]
    (priority, is_active)
    (is_deleted)
  }
}

Table approval_levels {
  id uuid [pk, default: `gen_random_uuid()`]
  expense_report_id uuid [not null, ref: > expense_reports.id]
  approver_user_id uuid [not null, ref: > users.id]
  level_number integer [not null]
  status approval_status [not null, default: 'pending']
  decision_date timestamp
  is_parallel boolean [not null, default: false]
  remarks text
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]

  indexes {
    (expense_report_id, level_number, approver_user_id) [unique]
    (approver_user_id, status)
    (status)
    (is_deleted)
  }
}

Table approval_history {
  id uuid [pk, default: `gen_random_uuid()`]
  expense_report_id uuid [not null, ref: > expense_reports.id]
  approval_level_id uuid [ref: > approval_levels.id]
  action approval_action [not null]
  performed_by uuid [not null, ref: > users.id]
  performed_at timestamp [not null, default: `now()`]
  remarks text
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]

  indexes {
    (expense_report_id, performed_at)
    (approval_level_id)
    (action)
    (performed_by, performed_at)
    (is_deleted)
  }
}

Table delegations {
  id uuid [pk, default: `gen_random_uuid()`]
  delegator_user_id uuid [not null, ref: > users.id]
  delegate_user_id uuid [not null, ref: > users.id]
  start_date timestamp [not null]
  end_date timestamp [not null]
  scope delegation_scope [not null, default: 'all']
  is_active boolean [not null, default: true]
  remarks text
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]

  indexes {
    (delegator_user_id, delegate_user_id, start_date, end_date)
    (delegate_user_id)
    (scope)
    (is_active)
    (is_deleted)
  }
}

}

Table payment_records {
  id uuid [pk, default: `gen_random_uuid()`]
  expense_report_id uuid [not null, ref: > expense_reports.id]
  bank_detail_id uuid [ref: > bank_details.id]
  payment_reference varchar(150) [not null, unique]
  payment_date date
  amount decimal(18,2) [not null]
  status payment_status [not null, default: 'pending']
  processed_by uuid [ref: > users.id]
  remarks text
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]

  indexes {
    (payment_reference) [unique]
    (expense_report_id)
    (bank_detail_id)
    (status, payment_date)
    (processed_by)
    (is_deleted)
  }
}

Table notifications {
  id uuid [pk, default: `gen_random_uuid()`]
  recipient_user_id uuid [not null, ref: > users.id]
  template_code varchar(100) [not null]
  channel notification_channel [not null]
  status notification_status [not null, default: 'pending']
  payload jsonb [not null, default: `'{}'`]
  sent_at timestamp
  read_at timestamp
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]

  indexes {
    (recipient_user_id, created_at)
    (channel)
    (status)
    (sent_at)
    (is_deleted)
  }
}

Table comments {
  id uuid [pk, default: `gen_random_uuid()`]
  expense_report_id uuid [not null, ref: > expense_reports.id]
  parent_comment_id uuid [ref: > comments.id]
  user_id uuid [not null, ref: > users.id]
  visibility comment_visibility [not null, default: 'public']
  comment_text text [not null]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]

  indexes {
    (expense_report_id, created_at)
    (parent_comment_id)
    (user_id)
    (visibility)
    (is_deleted)
  }
}

}

}

Table sessions {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null, ref: > users.id]
  session_token_hash text [not null, unique]
  ip_address varchar(100)
  user_agent text
  expires_at timestamp [not null]
  revoked_at timestamp
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]

  indexes {
    (session_token_hash) [unique]
    (user_id, expires_at)
    (revoked_at)
    (is_deleted)
  }
}

Table audit_logs {
  id uuid [pk, default: `gen_random_uuid()`]
  entity_name varchar(150) [not null]
  record_id uuid
  operation audit_operation [not null]
  before_json jsonb
  after_json jsonb
  performed_by uuid [ref: > users.id]
  performed_at timestamp [not null, default: `now()`]
  ip_address varchar(100)
  user_agent text
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp
  is_deleted boolean [not null, default: false]
  version integer [not null, default: 1]

  indexes {
    (entity_name, record_id)
    (operation)
    (performed_by, performed_at)
    (performed_at)
    (is_deleted)
  }
}

}

