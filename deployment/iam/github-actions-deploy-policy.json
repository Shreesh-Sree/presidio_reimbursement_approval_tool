{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "EcrAuthentication",
      "Effect": "Allow",
      "Action": ["ecr:GetAuthorizationToken"],
      "Resource": "*"
    },
    {
      "Sid": "PushPresidioServiceImages",
      "Effect": "Allow",
      "Action": [
        "ecr:BatchCheckLayerAvailability",
        "ecr:CompleteLayerUpload",
        "ecr:InitiateLayerUpload",
        "ecr:PutImage",
        "ecr:UploadLayerPart",
        "ecr:BatchGetImage",
        "ecr:GetDownloadUrlForLayer"
      ],
      "Resource": "arn:aws:ecr:ap-south-1:366731215001:repository/presidio-reimburse-prod/*"
    },
    {
      "Sid": "UpdateAppRunnerServices",
      "Effect": "Allow",
      "Action": [
        "apprunner:ListServices",
        "apprunner:DescribeService",
        "apprunner:UpdateService"
      ],
      "Resource": "*"
    },
    {
      "Sid": "PassOnlyRequiredAppRunnerRoles",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": [
        "arn:aws:iam::366731215001:role/presidio-apprunner-runtime",
        "arn:aws:iam::366731215001:role/presidio-apprunner-ecr-access"
      ],
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "tasks.apprunner.amazonaws.com"
        }
      }
    }
  ]
}
