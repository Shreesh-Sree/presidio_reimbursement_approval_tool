# Supabase project URL and browser-safe anon key. Never put the service-role key here.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Optional for a separately hosted API. Local Vite development uses /api via proxy.
VITE_API_BASE_URL=/api
VITE_FINGERPRINT_ENABLED=false
