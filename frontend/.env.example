# The browser-safe publishable key from Clerk. Never put Clerk secret keys here.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_with_your_clerk_publishable_key
# Custom Clerk JWT template used by the API; it must include verified email claims.
VITE_CLERK_JWT_TEMPLATE=presidio-api
# Optional for a separately hosted API. Local Vite development uses /api via proxy.
VITE_API_BASE_URL=/api
