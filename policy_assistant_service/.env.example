# This service intentionally has a separate SQLite file. Do not point it at
# DATABASE_URL or any PostgreSQL/core application database.
POLICY_ASSISTANT_DATABASE_PATH=var/policy-assistant.sqlite3

# Set a long random value outside source control. All /v1/* endpoints require it.
POLICY_ASSISTANT_SERVICE_TOKEN=replace-with-a-long-random-local-token

# The deterministic local retriever is the only active provider by default.
POLICY_ASSISTANT_PROVIDER_MODE=deterministic
POLICY_ASSISTANT_ENABLE_EXTERNAL_PROVIDER=false
