# Receipt Intelligence Service — Environment Configuration

# Service authentication token (required for API access)
RECEIPT_INTELLIGENCE_SERVICE_TOKEN=

# SQLite database path
RECEIPT_INTELLIGENCE_DATABASE_PATH=var/receipt-intelligence.sqlite3

# OCR settings
RECEIPT_INTELLIGENCE_OCR_ENABLED=true
RECEIPT_INTELLIGENCE_OCR_LANGUAGES=eng

# Groq LLM for intelligent receipt extraction (primary). Rule-based is fallback.
RECEIPT_INTELLIGENCE_GROQ_API_KEY=
RECEIPT_INTELLIGENCE_GROQ_MODEL=llama-3.3-70b-versatile
RECEIPT_INTELLIGENCE_GROQ_TIMEOUT_SECONDS=8
RECEIPT_INTELLIGENCE_GROQ_MAX_ATTEMPTS=2
